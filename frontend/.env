# DANGEROUSLY_DISABLE_HOST_CHECK=true
# WDS_SOCKET_HOST=127.0.0.1
# WDS_SOCKET_PORT=3000
# HOST=127.0.0.1

# ✅ Leave REACT_APP_API_URL empty — nginx proxy handles /api/ routing
# This means all API calls use relative paths like /api/chat/message
# which nginx forwards to ollama-backend-service:5005
REACT_APP_API_URL=

# WebSocket / HMR settings for AWS
DANGEROUSLY_DISABLE_HOST_CHECK=true
WDS_SOCKET_HOST=54.173.206.159
WDS_SOCKET_PORT=3000
HOST=54.173.206.159